# 百度千帆 v2 Bearer API Key。不要把真实值提交到 Git。
QIANFAN_API_KEY=

# 旧变量名仅作为 API Key 兼容别名；新部署只需设置 QIANFAN_API_KEY。
BAIDU_API_KEY=
WENXIN_APP_KEY=

# 模型与检索
# wheel 安装时可显式指定包含 .env 和 artifacts/ 的工作目录。
YDZ_PROJECT_ROOT=
YDZ_CHAT_MODEL=ernie-4.5-turbo-128k
YDZ_TEMPERATURE=0.9
YDZ_LLM_TIMEOUT_SECONDS=60
YDZ_EMBEDDING_MODEL=sentence-transformers/paraphrase-multilingual-mpnet-base-v2
YDZ_INDEX_DIR=artifacts/indexes/2018
YDZ_RETRIEVAL_K=3
YDZ_RETRIEVAL_MIN_SCORE=0.6

# HTTP 服务
YDZ_HOST=127.0.0.1
YDZ_PORT=8081
YDZ_DEBUG=false
YDZ_PUBLIC_BASE_URL=
YDZ_CORS_ORIGINS=https://yiyan.baidu.com
YDZ_MAX_QUERY_CHARS=10000

# 远程文档下载。默认仅允许公网 HTTPS 地址。
YDZ_DOWNLOAD_TIMEOUT_SECONDS=15
YDZ_DOWNLOAD_MAX_BYTES=20971520
YDZ_DOWNLOAD_MAX_REDIRECTS=3
YDZ_ALLOW_HTTP_DOWNLOADS=false
YDZ_ALLOWED_DOWNLOAD_HOSTS=

# 会话记忆
YDZ_MEMORY_TURNS=10
YDZ_MEMORY_SESSIONS=512

# 日志
YDZ_LOG_LEVEL=INFO
